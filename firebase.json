{
  "functions": [
    {
      "source": ".output/server",
      "codebase": "default",
      "runtime": "nodejs20",
      "ignore": ["node_modules", ".git"]
    }
  ],
  "hosting": {
    "public": ".output/public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "function": "server"
      }
    ]
  }
}
